<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- PARABOX Mobile — Templates Interface Livreur                          -->
<!-- Design professionnel · Fuseau Maroc · IP dynamique · Anti-annulation  -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->

<!-- ─────────────────────────────────────────────────────────────────────  -->
<!-- Layout principal                                                        -->
<!-- ─────────────────────────────────────────────────────────────────────  -->
<template id="layout_mobile" name="PARABOX Mobile Layout">
    <t t-call="web.layout">
        <t t-set="head">
            <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
            <meta name="mobile-web-app-capable" content="yes"/>
            <meta name="apple-mobile-web-app-capable" content="yes"/>
            <meta name="theme-color" content="#1a252f"/>
            <title>PARABOX Livreur</title>
            <style><![CDATA[
:root {
    --primary: #1e3a5f;
    --primary-light: #2e5d9f;
    --accent: #e74c3c;
    --success: #27ae60;
    --warning: #f39c12;
    --info: #2980b9;
    --text: #2c3e50;
    --text-muted: #7f8c8d;
    --bg: #f4f6f9;
    --card: #ffffff;
    --border: #e8ecf0;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
    --radius: 14px;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
       background: var(--bg); color: var(--text); font-size: 15px; line-height: 1.5; }

/* ── Header ── */
.mob-header {
    background: linear-gradient(160deg, var(--primary) 0%, var(--primary-light) 100%);
    color: white; padding: 14px 18px;
    position: sticky; top: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: 0 3px 16px rgba(0,0,0,0.25);
}
.mob-logo { font-size: 18px; font-weight: 900; letter-spacing: 1px; }
.mob-logo span { color: #5dade2; }
.mob-subtitle { font-size: 11px; opacity: 0.65; margin-top: 2px; }
.mob-badge {
    background: var(--accent); color: white;
    border-radius: 50px; padding: 4px 12px;
    font-size: 14px; font-weight: 700; min-width: 32px; text-align: center;
}
.mob-badge.zero { background: rgba(255,255,255,0.2); }

/* ── Container ── */
.mob-container { padding: 14px; max-width: 960px; margin: 0 auto; }
@media (min-width: 768px) {
    .mob-container { padding: 20px 28px; }
}

/* ── Section label ── */
.section-label {
    font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--text-muted); font-weight: 700;
    margin: 20px 0 10px; padding-left: 2px;
    display: flex; align-items: center; gap: 8px;
}
.section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

/* ── BL Card ── */
.bl-card {
    background: var(--card); border-radius: var(--radius);
    padding: 16px; margin: 8px 0;
    box-shadow: var(--shadow);
    border-left: 5px solid var(--border);
    text-decoration: none; display: block; color: inherit;
    transition: transform 0.12s, box-shadow 0.12s;
    position: relative; overflow: hidden;
}
.bl-card:active { transform: scale(0.985); box-shadow: 0 1px 6px rgba(0,0,0,0.1); }
.bl-card.state-assigned   { border-left-color: var(--info); }
.bl-card.state-confirmed  { border-left-color: var(--warning); }
.bl-card.state-signed     { border-left-color: var(--success); }
.bl-card.state-otp        { border-left-color: #8e44ad; }
.bl-card.state-done       { border-left-color: var(--success); opacity: 0.75; }

.bl-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.bl-name { font-size: 17px; font-weight: 800; color: var(--primary); }
.bl-status {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 700; white-space: nowrap;
}
.s-assigned  { background: #d6eaf8; color: #1a5276; }
.s-confirmed { background: #fef9e7; color: #784212; }
.s-signed    { background: #d5f5e3; color: #1e8449; }
.s-otp       { background: #e8daef; color: #6c3483; }
.s-done      { background: #d5f5e3; color: #1e8449; }

.bl-client { font-size: 14px; color: var(--text); font-weight: 500; margin-bottom: 4px; }
.bl-meta { font-size: 12px; color: var(--text-muted); display: flex; gap: 14px; margin-top: 4px; flex-wrap: wrap; }
.bl-meta span { display: flex; align-items: center; gap: 4px; }
.bl-footer { display: flex; justify-content: flex-end; margin-top: 10px; }
.bl-arrow { color: var(--text-muted); font-size: 20px; font-weight: 300; }

/* ── Detail header ── */
.detail-header {
    background: linear-gradient(160deg, var(--primary) 0%, var(--primary-light) 100%);
    color: white; padding: 12px 16px;
    display: flex; align-items: center; gap: 12px;
    position: sticky; top: 0; z-index: 200;
    box-shadow: 0 3px 16px rgba(0,0,0,0.25);
}
.btn-back {
    background: rgba(255,255,255,0.18); border: none; color: white;
    padding: 8px 16px; border-radius: 8px; font-size: 14px; font-weight: 700;
    cursor: pointer; text-decoration: none; display: inline-block;
    transition: background 0.15s;
}
.btn-back:active { background: rgba(255,255,255,0.3); }
.detail-title { flex: 1; }
.detail-title h2 { font-size: 17px; font-weight: 800; }
.detail-title p  { font-size: 12px; opacity: 0.7; margin-top: 2px; }
.detail-state {
    background: rgba(255,255,255,0.15); border-radius: 6px;
    padding: 4px 10px; font-size: 12px; font-weight: 600; white-space: nowrap;
}

/* ── Cards ── */
.info-card, .sign-card, .section-card {
    background: var(--card); border-radius: var(--radius);
    padding: 18px; margin: 8px 0;
    box-shadow: var(--shadow);
}
.card-title { font-size: 13px; font-weight: 700; color: var(--text-muted);
              text-transform: uppercase; letter-spacing: 1px; margin-bottom: 14px; }
.info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 14px;
}
.info-row:last-child { border-bottom: none; }
.info-label { color: var(--text-muted); }
.info-value { font-weight: 600; color: var(--text); text-align: right; max-width: 60%; }

/* ── Produits ── */
.product-item {
    background: var(--card); border-radius: 10px;
    padding: 14px 16px; margin: 6px 0;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
    display: flex; justify-content: space-between; align-items: center;
    border-left: 3px solid var(--border);
}
.product-item.has-lots { border-left-color: var(--primary-light); }
.product-info { flex: 1; margin-right: 12px; }
.product-name { font-size: 14px; font-weight: 600; color: var(--text); }
.product-lot  { font-size: 12px; color: var(--text-muted); margin-top: 3px; }
.product-qty-wrap { text-align: right; }
.product-qty { font-size: 26px; font-weight: 800; color: var(--primary-light); line-height: 1; }
.product-uom { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

/* ── Boutons ── */
.btn-mobile {
    width: 100%; padding: 16px; font-size: 15px;
    border-radius: 12px; border: none; cursor: pointer;
    font-weight: 700; margin: 6px 0; letter-spacing: 0.2px;
    transition: opacity 0.18s, transform 0.1s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
}
.btn-mobile:active { transform: scale(0.97); opacity: 0.85; }
.btn-mobile:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-primary { background: linear-gradient(135deg, var(--primary-light), var(--info)); color: white; }
.btn-success { background: linear-gradient(135deg, var(--success), #2ecc71); color: white; }
.btn-warning { background: linear-gradient(135deg, var(--warning), #e67e22); color: white; }
.btn-secondary { background: var(--border); color: var(--text); }

/* ── Messages ── */
.msg-box {
    padding: 14px 16px; border-radius: 10px; font-size: 14px; margin: 8px 0;
    display: flex; align-items: flex-start; gap: 10px;
}
.msg-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.msg-success { background: #eafaf1; color: #1e8449; border: 1px solid #a9dfbf; }
.msg-error   { background: #fdedec; color: #922b21; border: 1px solid #f1948a; }
.msg-warning { background: #fef9e7; color: #784212; border: 1px solid #f9e79f; }
.msg-info    { background: #eaf4fb; color: #1a5276; border: 1px solid #aed6f1; }
.msg-cancel  { background: #fdedec; color: #7b241c; border: 1px solid #f1948a; }

/* ── URL Box ── */
.url-box {
    background: #eaf4fb; border: 1px dashed var(--info); border-radius: 8px;
    padding: 12px; margin: 8px 0; word-break: break-all; font-size: 13px;
    color: var(--info); font-family: monospace;
}

/* ── BL Cards Grid — tablet/desktop ── */
.bl-cards-grid { display: grid; grid-template-columns: 1fr; gap: 8px; }
@media (min-width: 600px) { .bl-cards-grid { grid-template-columns: 1fr 1fr; } }
@media (min-width: 900px) { .bl-cards-grid { grid-template-columns: 1fr 1fr 1fr; } }

/* ── Empty state ── */
.empty-state { text-align: center; padding: 60px 24px; color: var(--text-muted); }
.empty-icon { font-size: 64px; margin-bottom: 16px; filter: grayscale(0.3); }
.empty-title { font-size: 17px; font-weight: 700; margin-bottom: 8px; color: var(--text); }
.empty-sub   { font-size: 14px; color: var(--text-muted); }

/* ── KPI strip ── */
.kpi-strip { display: flex; gap: 10px; margin: 12px 0; }
.kpi-box {
    flex: 1; background: var(--card); border-radius: 12px;
    padding: 14px 10px; text-align: center; box-shadow: var(--shadow);
}
.kpi-num { font-size: 28px; font-weight: 900; color: var(--primary); }
.kpi-lbl { font-size: 11px; color: var(--text-muted); margin-top: 2px; font-weight: 600; }

/* ── Alert banner ── */
.alert-banner {
    background: #fdedec; border: 2px solid var(--accent);
    border-radius: var(--radius); padding: 16px 18px; margin: 8px 0;
    font-size: 15px; font-weight: 600; color: var(--accent);
    display: flex; align-items: center; gap: 12px;
}

/* ── Spinner ── */
@keyframes spin { to { transform: rotate(360deg); } }
.spinner { display: inline-block; width: 18px; height: 18px; border: 3px solid rgba(255,255,255,0.4);
           border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; }
            ]]></style>
        </t>
        <body>
            <t t-out="0"/>
        </body>
    </t>
</template>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- Page erreur générique                                                   -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<template id="page_erreur" name="Erreur PARABOX">
    <t t-call="parabox_mobile.layout_mobile">
        <div class="mob-header">
            <div><div class="mob-logo">PARA<span>BOX</span></div></div>
        </div>
        <div class="mob-container">
            <div class="empty-state">
                <div class="empty-icon"><i class="fa fa-exclamation-triangle" style="font-size:56px;color:#e74c3c;"/></div>
                <div class="empty-title">Une erreur est survenue</div>
                <p class="empty-sub" style="margin-bottom:20px;"><t t-esc="message"/></p>
                <a t-attf-href="#{base_url}/parabox/mobile/livreur" class="btn-mobile btn-primary" style="display:inline-flex;width:auto;padding:12px 28px;">
                    ← Retour à l'accueil
                </a>
            </div>
        </div>
    </t>
</template>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- Page 1 : Liste des BL du livreur                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<template id="page_livreur_home" name="Espace Livreur — Liste BL">
    <t t-call="parabox_mobile.layout_mobile">

        <!-- Header -->
        <div class="mob-header">
            <div>
                <div class="mob-logo">PARA<span>BOX</span></div>
                <div class="mob-subtitle">Espace Livreur — <t t-esc="today"/></div>
            </div>
            <div t-if="total_pending > 0" class="mob-badge"><t t-esc="total_pending"/></div>
            <div t-else="" class="mob-badge zero">0</div>
        </div>

        <div class="mob-container">

            <!-- KPIs -->
            <div class="kpi-strip" style="margin-top:14px;">
                <div class="kpi-box">
                    <div class="kpi-num" style="color:var(--warning);"><t t-esc="total_pending"/></div>
                    <div class="kpi-lbl">En cours</div>
                </div>
                <div class="kpi-box">
                    <div class="kpi-num" style="color:var(--success);"><t t-esc="len(bls_done_data)"/></div>
                    <div class="kpi-lbl">Livrés aujourd'hui</div>
                </div>
                <div class="kpi-box">
                    <div class="kpi-num" style="color:var(--primary);">
                        <t t-esc="len([x for x in bls_data if x['signed']])"/>
                    </div>
                    <div class="kpi-lbl">Signés</div>
                </div>
            </div>

            <!-- Liste BL en cours -->
            <div t-if="not bls_data" class="empty-state">
                <div class="empty-icon"><i class="fa fa-check-circle" style="font-size:56px;color:#27ae60;"/></div>
                <div class="empty-title">Aucune livraison en cours</div>
                <p class="empty-sub">Les bons de livraison confirmés par le magasinier apparaîtront ici.</p>
            </div>

            <div t-if="bls_data">
                <div class="section-label">Livraisons en cours</div>
                <div class="bl-cards-grid">
                <t t-foreach="bls_data" t-as="item" t-key="item['bl'].id">
                    <a t-attf-href="#{base_url}/parabox/mobile/livreur/bl/#{item['bl'].id}"
                       t-att-class="'bl-card ' + ('state-signed' if item['signed'] else ('state-otp' if item['otp_sent'] else ('state-assigned' if item['bl'].state == 'assigned' else 'state-confirmed')))">
                        <div class="bl-header">
                            <div class="bl-name"><i class="fa fa-file-text-o"/> <t t-esc="item['bl'].name"/></div>
                            <div t-if="item['signed']"     class="bl-status s-signed"><i class="fa fa-check"/> Signé</div>
                            <div t-elif="item['otp_sent']" class="bl-status s-otp"><i class="fa fa-envelope-o"/> OTP</div>
                            <div t-elif="item['bl'].state == 'assigned'"  class="bl-status s-assigned"><i class="fa fa-check-circle-o"/> Prêt</div>
                            <div t-else=""                 class="bl-status s-confirmed"><i class="fa fa-clock-o"/> Attente</div>
                        </div>
                        <div class="bl-client"><i class="fa fa-user-o"/> <t t-esc="item['bl'].partner_id.name"/></div>
                        <div class="bl-meta">
                            <span t-if="item['scheduled_local']">
                                <i class="fa fa-clock-o"/> <t t-esc="item['scheduled_local'].strftime('%d/%m à %H:%M')"/>
                            </span>
                            <span><i class="fa fa-cube"/> <t t-esc="len(item['bl'].move_ids)"/> produit(s)</span>
                        </div>
                        <div class="bl-footer"><span class="bl-arrow">›</span></div>
                    </a>
                </t>
                </div>
            </div>

            <!-- BL validés aujourd'hui -->
            <div t-if="bls_done_data">
                <div class="section-label">Livrés aujourd'hui</div>
                <t t-foreach="bls_done_data" t-as="item" t-key="item['bl'].id">
                    <div class="bl-card state-done">
                        <div class="bl-header">
                            <div class="bl-name"><i class="fa fa-check-square-o"/> <t t-esc="item['bl'].name"/></div>
                            <div class="bl-status s-done">Livré</div>
                        </div>
                        <div class="bl-client"><i class="fa fa-user-o"/> <t t-esc="item['bl'].partner_id.name"/></div>
                    </div>
                </t>
            </div>

            <div style="height:28px;"></div>
        </div>
    </t>
</template>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- Page 2 : Détail d'un BL                                                -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<template id="page_livreur_bl_detail" name="Détail BL">
    <t t-call="parabox_mobile.layout_mobile">

        <!-- Header avec bouton retour et statut -->
        <div class="detail-header">
            <a t-attf-href="#{base_url}/parabox/mobile/livreur" class="btn-back">← Retour</a>
            <div class="detail-title">
                <h2><t t-esc="bl.name"/></h2>
                <p><t t-esc="bl.partner_id.name"/></p>
            </div>
            <div class="detail-state"><t t-esc="state_label"/></div>
        </div>

        <div class="mob-container">

            <!-- ── BL ANNULÉ ─────────────────────────────────────── -->
            <div t-if="bl_cancelled">
                <div class="alert-banner" style="margin-top:16px;">
                    <i class="fa fa-times-circle" style="font-size:28px;color:var(--accent);"/>
                    <div>
                        <div>Ce bon de livraison a été <strong>annulé</strong>.</div>
                        <div style="font-size:13px;font-weight:400;margin-top:4px;color:var(--text);">
                            Il a été annulé par le magasinier dans Odoo.<br/>
                            Contactez le responsable logistique pour plus d'informations.
                        </div>
                    </div>
                </div>
                <div style="text-align:center;padding:28px 0;">
                    <a t-attf-href="#{base_url}/parabox/mobile/livreur" class="btn-mobile btn-primary" style="display:inline-flex;width:auto;padding:14px 32px;">
                        ← Revenir à la liste
                    </a>
                </div>
            </div>

            <!-- ── BL NORMAL ─────────────────────────────────────── -->
            <div t-if="not bl_cancelled">

                <!-- Infos générales -->
                <div class="section-label" style="margin-top:14px;">Informations</div>
                <div class="info-card">
                    <div class="info-row">
                        <span class="info-label">Référence</span>
                        <span class="info-value" style="color:var(--primary-light);font-size:16px;font-weight:800;"><t t-esc="bl.name"/></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Client</span>
                        <span class="info-value"><t t-esc="bl.partner_id.name"/></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email client</span>
                        <span class="info-value" style="font-size:12px;"><t t-esc="bl.partner_id.email or '—'"/></span>
                    </div>
                    <div class="info-row" t-if="scheduled_local">
                        <span class="info-label">Livraison prévue</span>
                        <span class="info-value"><t t-esc="scheduled_local.strftime('%d/%m/%Y à %H:%M')"/></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Statut</span>
                        <span class="info-value">
                            <t t-if="bl.state == 'assigned'"><span class="bl-status s-assigned"><i class="fa fa-check-circle-o"/> Prêt à livrer</span></t>
                            <t t-elif="bl.state == 'confirmed'"><span class="bl-status s-confirmed"><i class="fa fa-clock-o"/> Stock non réservé</span></t>
                            <t t-elif="bl.state == 'done'"><span class="bl-status s-done"><i class="fa fa-check-square"/> Validé</span></t>
                            <t t-else=""><t t-esc="state_label"/></t>
                        </span>
                    </div>
                </div>

                <!-- Produits -->
                <div class="section-label">Produits à livrer (<t t-esc="len(lignes)"/>)</div>
                <div t-if="not lignes" class="msg-box msg-warning">
                    <i class="fa fa-exclamation-triangle msg-icon"/>
                    <span>Aucun produit dans ce bon de livraison.</span>
                </div>
                <t t-foreach="lignes" t-as="ligne" t-key="ligne_index">
                    <div t-att-class="'product-item' + (' has-lots' if ligne['has_lots'] else '')">
                        <div class="product-info">
                            <div class="product-name"><t t-esc="ligne['product_name']"/></div>
                            <div class="product-lot" t-if="ligne['has_lots']">
                                <i class="fa fa-tag"/> Lots : <t t-esc="', '.join(ligne['lots'])"/>
                            </div>
                        </div>
                        <div class="product-qty-wrap">
                            <div class="product-qty"><t t-esc="ligne['qty_done']"/> / <span style="font-size:16px;color:var(--text-muted);"><t t-esc="ligne['qty_ordered']"/></span></div>
                            <div class="product-uom"><t t-esc="ligne['uom']"/></div>
                        </div>
                    </div>
                </t>

                <!-- Section Signature -->
                <div class="section-label">Signature client</div>
                <div class="sign-card">

                    <!-- Déjà signé -->
                    <div t-if="sign_req and sign_req.signed">
                        <div class="msg-box msg-success">
                            <i class="fa fa-check-circle msg-icon"/>
                            <div>
                                <strong>BL signé</strong><br/>
                                <t t-esc="sign_req.sign_datetime.strftime('Le %d/%m/%Y à %H:%M') if sign_req.sign_datetime else '—'"/>
                                <br/>Mode : <t t-esc="sign_req.mode"/>
                            </div>
                        </div>
                        <a t-attf-href="#{base_url}/parabox/sign/pdf/#{sign_req.token}"
                           class="btn-mobile btn-success" style="display:flex;text-decoration:none;margin-top:12px;">
                            <i class="fa fa-download"/> Télécharger le BL signé
                        </a>
                    </div>

                    <!-- OTP envoyé, en attente -->
                    <div t-elif="sign_req and sign_req.otp_sent and not sign_req.signed">
                        <div class="msg-box msg-info">
                            <i class="fa fa-envelope-o msg-icon"/>
                            <div>
                                OTP envoyé à <strong><t t-esc="bl.partner_id.email"/></strong><br/>
                                En attente de signature du client.
                            </div>
                        </div>
                        <div class="url-box">
                            <strong>URL de signature :</strong><br/>
                            <t t-esc="sign_url"/>
                        </div>
                        <button id="btn-send-otp" onclick="sendOtp(this)" class="btn-mobile btn-warning">
                            <i class="fa fa-repeat"/> Renvoyer l'OTP
                        </button>
                    </div>

                    <!-- Pas encore d'OTP -->
