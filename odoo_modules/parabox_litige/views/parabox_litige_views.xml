<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view -->
    <record id="view_parabox_litige_form" model="ir.ui.view">
        <field name="name">parabox.litige.form</field>
        <field name="model">parabox.litige</field>
        <field name="arch" type="xml">
            <form string="Litige PARABOX">
                <header>
                    <field name="stage_id" widget="statusbar"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="[('sla_statut', '!=', 'escalade')]">
                        <strong>ESCALADE DIRECTION :</strong> Ce litige dépasse 7 jours sans résolution.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="[('sla_statut', '!=', 'alerte')]">
                        <strong>ALERTE :</strong> Ce litige est ouvert depuis plus de 3 jours.
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="partner_id"/>
                            <field name="type_litige"/>
                            <field name="responsable_id"/>
                            <field name="montant_litige"/>
                        </group>
                        <group string="SLA">
                            <field name="date_ouverture"/>
                            <field name="date_resolution"/>
                            <field name="delai_jours" readonly="1"/>
                            <field name="sla_statut" readonly="1"/>
                        </group>
                    </group>
                    <group string="Documents liés">
                        <field name="sale_order_id"/>
                        <field name="picking_id"/>
                        <field name="invoice_id"/>
                        <field name="avoir_id"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Résolution" invisible="[('stage_id.is_closed', '=', False)]">
                        <field name="resolution_note" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="view_parabox_litige_kanban" model="ir.ui.view">
        <field name="name">parabox.litige.kanban</field>
        <field name="model">parabox.litige</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                    class="o_kanban_small_column"
                    quick_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="type_litige"/>
                <field name="montant_litige"/>
                <field name="delai_jours"/>
                <field name="sla_statut"/>
                <field name="stage_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click
                                           #{record.sla_statut.raw_value == 'escalade' ? 'oe_kanban_color_2' :
                                             record.sla_statut.raw_value == 'alerte' ? 'oe_kanban_color_4' : ''}">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong><br/>
                                <field name="partner_id"/>
                                <div class="text-muted">
                                    <field name="type_litige"/> —
                                    <field name="montant_litige"/> DH
                                </div>
                                <div>
                                    <field name="sla_statut"/> |
                                    <field name="delai_jours"/> jours
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tree view -->
    <record id="view_parabox_litige_tree" model="ir.ui.view">
        <field name="name">parabox.litige.tree</field>
        <field name="model">parabox.litige</field>
        <field name="arch" type="xml">
            <tree string="Litiges"
                  decoration-danger="sla_statut == 'escalade'"
                  decoration-warning="sla_statut == 'alerte'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="type_litige"/>
                <field name="stage_id"/>
                <field name="date_ouverture"/>
                <field name="delai_jours"/>
                <field name="sla_statut"/>
                <field name="montant_litige"/>
                <field name="responsable_id"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_parabox_litige" model="ir.actions.act_window">
        <field name="name">Litiges PARABOX</field>
        <field name="res_model">parabox.litige</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_stage_id': 1}</field>
    </record>

    <!-- Menu — Litiges : Direction + Commercial + Comptable -->
    <menuitem id="menu_parabox_litige"
              name="Litiges"
              parent="parabox_logistics_tracking.menu_parabox_logistics_root"
              action="action_parabox_litige"
              sequence="20"
              groups="parabox_logistics_tracking.group_parabox_direction,parabox_logistics_tracking.group_parabox_commercial,parabox_logistics_tracking.group_parabox_comptable"/>
</odoo>
