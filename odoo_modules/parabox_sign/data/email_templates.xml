    <record id="smtp_parabox_gmail" model="ir.mail_server">
        <field name="name">PARABOX Gmail SMTP</field>
        <field name="smtp_host">smtp.gmail.com</field>
        <field name="smtp_port">587</field>
        <field name="smtp_encryption">starttls</field>
        <field name="smtp_user">ernestlompo28@gmail.com</field>
        <field name="smtp_pass">oafmxmjlvlwznhbb</field>
        <field name="sequence">1</field>
    </record>

</odoo>
