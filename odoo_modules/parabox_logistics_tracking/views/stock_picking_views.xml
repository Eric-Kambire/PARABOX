<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Onglet traçabilité dans le bon de livraison -->
    <record id="view_picking_logistics_form" model="ir.ui.view">
        <field name="name">stock.picking.logistics.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Tracabilite PARABOX" name="logistics_tracking"
                      invisible="[('picking_type_code', '!=', 'outgoing')]">
                    <group>
                        <field name="taux_service_global" string="Taux de service global (%)"
                               widget="percentage" readonly="1"/>
                        <field name="has_logistics_ecart" string="Écarts détectés" readonly="1"/>
                    </group>
                    <field name="logistics_line_ids">
                        <tree editable="bottom"
                              decoration-danger="has_ecart == True"
                              decoration-success="taux_service &gt;= 100">
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="qty_ordered"/>
                            <field name="qty_prepared"/>
                            <field name="qty_loaded"/>
                            <field name="qty_delivered"/>
                            <field name="ecart_total" readonly="1"/>
                            <field name="taux_service" widget="percentage" readonly="1"/>
                            <field name="has_ecart" column_invisible="1"/>
                            <field name="substitution"/>
                            <field name="note_ecart"/>
                        </tree>
                    </field>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
