<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view -->
    <record id="view_parabox_logistics_line_form" model="ir.ui.view">
        <field name="name">parabox.logistics.line.form</field>
        <field name="model">parabox.logistics.line</field>
        <field name="arch" type="xml">
            <form string="Traçabilité logistique">
                <sheet>
                    <group>
                        <group string="Document">
                            <field name="picking_id"/>
                            <field name="sale_order_id"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                        </group>
                        <group string="Quantités">
                            <field name="qty_ordered"/>
                            <field name="qty_prepared"/>
                            <field name="qty_loaded"/>
                            <field name="qty_delivered"/>
                        </group>
                    </group>
                    <group string="Écarts">
                        <group>
                            <field name="ecart_preparation" readonly="1"/>
                            <field name="ecart_livraison" readonly="1"/>
                            <field name="ecart_total" readonly="1"/>
                            <field name="taux_service" readonly="1" widget="percentage"/>
                        </group>
                        <group>
                            <field name="substitution"/>
                            <field name="product_sub_id"
                                   invisible="[('substitution', '=', False)]"/>
                            <field name="note_ecart"/>
                        </group>
                    </group>
                    <group string="Traçabilité temporelle">
                        <group string="Timestamps">
                            <field name="datetime_t1" readonly="1"/>
                            <field name="datetime_t2" readonly="1"/>
                            <field name="datetime_t3" readonly="1"/>
                        </group>
                        <group string="Durées">
                            <field name="duree_prise_en_charge" readonly="1"/>
                            <field name="duree_livraison" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree view -->
    <record id="view_parabox_logistics_line_tree" model="ir.ui.view">
        <field name="name">parabox.logistics.line.tree</field>
        <field name="model">parabox.logistics.line</field>
        <field name="arch" type="xml">
            <tree string="Traçabilité logistique"
                  decoration-danger="has_ecart == True"
                  decoration-success="taux_service &gt;= 100">
                <field name="picking_id"/>
                <field name="sale_order_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="qty_ordered"/>
                <field name="qty_prepared"/>
                <field name="qty_loaded"/>
                <field name="qty_delivered"/>
                <field name="ecart_total"/>
                <field name="taux_service" widget="percentage"/>
                <field name="has_ecart" column_invisible="1"/>
                <field name="substitution"/>
                <field name="datetime_t1"/>
                <field name="datetime_t2"/>
                <field name="datetime_t3"/>
                <field name="duree_prise_en_charge"/>
                <field name="duree_livraison"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_parabox_logistics_line" model="ir.actions.act_window">
        <field name="name">Traçabilité logistique</field>
        <field name="res_model">parabox.logistics.line</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus déplacés dans views/menus.xml (chargé en dernier) -->
    <!-- pour éviter "External ID not found" lors de l'upgrade des groupes -->
</odoo>
