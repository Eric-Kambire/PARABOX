<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Onglet alias dans la fiche produit -->
    <record id="view_product_template_alias_form" model="ir.ui.view">
        <field name="name">product.template.alias.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Alias PARABOX" name="alias_parabox">
                    <field name="alias_ids">
                        <tree editable="bottom">
                            <field name="fournisseur_id"/>
                            <field name="code_parabox"/>
                            <field name="code_fournisseur"/>
                            <field name="code_revendeur"/>
                            <field name="ean"/>
                            <field name="actif"/>
                        </tree>
                    </field>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
