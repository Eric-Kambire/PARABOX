<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Bouton accès plan encaissement depuis la facture -->
    <record id="view_move_encaissement_form" model="ir.ui.view">
        <field name="name">account.move.encaissement.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_encaissement"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        invisible="[('move_type', 'not in', ['out_invoice'])]">
                    <field name="encaissement_count" widget="statinfo" string="Encaissements"/>
                </button>
            </div>
        </field>
    </record>
</odoo>
